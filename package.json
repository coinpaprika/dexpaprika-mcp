{
  "name": "dexpaprika-mcp",
  "version": "2.1.1",
  "description": "A Model Context Protocol server for DexPaprika cryptocurrency data with network-specific pool queries",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "dexpaprika-mcp": "./dist/bin.js"
  },
  "scripts": {
    "build": "mkdir -p dist && cp -r src/* dist/ && chmod +x dist/bin.js",
    "start": "node src/index.js",
    "watch": "nodemon --watch src --exec npm start",
    "test": "node src/test.js",
    "test:api": "node src/test_methods.js",
    "test:mcp": "node src/test_mcp_client.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dexpaprika",
    "cryptocurrency",
    "defi",
    "dex",
    "decentralized-exchange",
    "blockchain",
    "liquidity-pools"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/coinpaprika/dexpaprika-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coinpaprika/dexpaprika-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/coinpaprika/dexpaprika-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.24.2"
  }
}
